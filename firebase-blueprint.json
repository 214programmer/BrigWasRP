{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["citizen", "deputy", "leader", "admin_1", "admin_2", "admin_3", "deputy_superadmin", "superadmin"] },
        "factionId": { "type": "string", "description": "Optional id of the faction" }
      },
      "required": ["email", "username", "role"]
    },
    "Faction": {
      "title": "Faction",
      "description": "Faction in the game",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "Category": {
      "title": "Category",
      "description": "Forum category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["main", "faction", "general"] },
        "factionId": { "type": "string" }
      },
      "required": ["name", "type"]
    },
    "Topic": {
      "title": "Topic",
      "description": "A discussion topic",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "title": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["categoryId", "title", "authorId", "createdAt", "updatedAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A reply inside a topic (or the main content)",
      "type": "object",
      "properties": {
        "topicId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["topicId", "authorId", "content", "createdAt", "updatedAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["postId", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/factions/{factionId}": {
      "schema": { "$ref": "#/entities/Faction" },
      "description": "Factions"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories"
    },
    "/topics/{topicId}": {
      "schema": { "$ref": "#/entities/Topic" },
      "description": "Topics within categories"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Posts within topics"
    },
    "/likes/{likeId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Likes on posts"
    }
  }
}
