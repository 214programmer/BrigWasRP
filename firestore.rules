rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      // Allow specific emails to be admins or anyone who has role "superadmin" in users collection.
      // Actually we will simplify it for the moment.
      return request.auth != null && (
        request.auth.token.email == 'prudnikovdanja@gmail.com' ||
        request.auth.token.email == 'ivanprudnikov363@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
      );
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if true; 
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /topics/{topicId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
    }
  }
}
