rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function getUserFactionId() {
      let docData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return docData.get('factionId', null);
    }
    
    function isSuperAdmin() { return isSignedIn() && getUserRole() == 'superadmin'; }
    function isAdmin() { 
      let r = getUserRole();
      return isSignedIn() && (r == 'admin_1' || r == 'admin_2' || r == 'admin_3' || r == 'deputy_superadmin' || r == 'superadmin'); 
    }
    // Citizen is any registered user. Let's assume creating topics is leader+ in specific or admin.

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      function isValidUser(data) {
        return data.size() >= 3 && data.size() <= 4
          && data.keys().hasAll(['email', 'username', 'role'])
          && data.email is string && data.email.size() <= 100
          && data.username is string && data.username.size() <= 40
          && data.role is string && data.role in ['citizen', 'deputy', 'leader', 'admin_1', 'admin_2', 'admin_3', 'deputy_superadmin', 'superadmin'];
      }
      
      allow read: if true; // Open to read
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidUser(incoming()) 
        && (incoming().role == 'citizen' || (request.auth.token.email == 'prudnikovdanja@gmail.com' && incoming().role == 'superadmin'));
        
      allow update: if isSignedIn() && isValidUser(incoming())
        && (
          (isSuperAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'factionId']))
          ||
          (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['username']))
          ||
          (request.auth.uid == userId && request.auth.token.email == 'prudnikovdanja@gmail.com' && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'username']) && incoming().role == 'superadmin')
        );
        
      // No self-update here except maybe username if allowed, but to keep simple only superadmin updates roles
    }

    match /factions/{factionId} {
      function isValidFaction(data) {
        return data.keys().hasAll(['name', 'description']) && data.size() == 2
          && data.name is string && data.name.size() <= 100
          && data.description is string && data.description.size() <= 1000;
      }
      allow read: if true;
      allow create: if isSuperAdmin() && isValidFaction(incoming());
      allow update: if isSuperAdmin() && isValidFaction(incoming());
      allow delete: if isSuperAdmin();
    }

    match /categories/{categoryId} {
      function isValidCat(data) {
        return data.keys().hasAll(['name', 'type']) && data.size() >= 2 && data.size() <= 4
          && data.name is string && data.name.size() <= 100
          && data.type in ['main', 'faction', 'general'];
      }
      allow read: if true;
      allow create: if isSuperAdmin() && isValidCat(incoming());
      allow update: if isSuperAdmin() && isValidCat(incoming());
      allow delete: if isSuperAdmin();
    }

    match /topics/{topicId} {
      function isValidTopic(data) {
        return data.keys().hasAll(['categoryId', 'title', 'authorId', 'createdAt', 'updatedAt'])
               && data.size() == 5
               && data.categoryId is string && data.categoryId.size() <= 128
               && data.title is string && data.title.size() <= 200 && data.title.size() > 0
               && data.authorId == request.auth.uid
               && data.createdAt == request.time
               && data.updatedAt == request.time;
      }
      function isValidTopicUpdate(data) {
        return data.keys().hasAll(['categoryId', 'title', 'authorId', 'createdAt', 'updatedAt'])
               && data.size() == 5
               && data.categoryId == existing().categoryId
               && data.authorId == existing().authorId
               && data.createdAt == existing().createdAt
               && data.updatedAt == request.time
               && data.title is string && data.title.size() <= 200;
      }
      
      function canCreateTopic(data) {
        let catUrl = /databases/$(database)/documents/categories/$(data.categoryId);
        let cat = get(catUrl).data;
        let role = getUserRole();
        let factionId = getUserFactionId();
        
        // Admins and Superadmins can create anywhere (except maybe faction if we restrict, but let's allow)
        return (role == 'admin_1' || role == 'admin_2' || role == 'admin_3' || role == 'deputy_superadmin' || role == 'superadmin') ||
               ((role == 'leader' || role == 'deputy') && cat.type == 'faction' && cat.factionId == factionId);
      }

      allow read: if true;
      allow create: if isSignedIn() && isValidId(topicId) 
                    && isValidTopic(incoming()) 
                    && exists(/databases/$(database)/documents/categories/$(incoming().categoryId))
                    && canCreateTopic(incoming());
                    
      allow update: if isSignedIn() && isValidTopicUpdate(incoming())
                    && (isSuperAdmin() || isAdmin() || existing().authorId == request.auth.uid)
                    && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);
                    
      allow delete: if isSuperAdmin() || isAdmin();
    }

    match /posts/{postId} {
      function isValidPost(data) {
        return data.keys().hasAll(['topicId', 'authorId', 'content', 'createdAt', 'updatedAt']) 
               && data.size() == 5
               && data.topicId is string && data.topicId.size() <= 128
               && data.content is string && data.content.size() <= 5000 && data.content.size() > 0
               && data.authorId == request.auth.uid
               && data.createdAt == request.time
               && data.updatedAt == request.time;
      }
      function isValidPostUpdate(data) {
        return data.keys().hasAll(['topicId', 'authorId', 'content', 'createdAt', 'updatedAt']) 
               && data.size() == 5
               && data.topicId == existing().topicId
               && data.authorId == existing().authorId
               && data.createdAt == existing().createdAt
               && data.updatedAt == request.time
               && data.content is string && data.content.size() <= 5000;
      }
      
      allow read: if true;
      allow create: if isSignedIn() && isValidId(postId)
                    && isValidPost(incoming())
                    && exists(/databases/$(database)/documents/topics/$(incoming().topicId));
      allow update: if isSignedIn() && isValidPostUpdate(incoming())
                    && (isSuperAdmin() || isAdmin() || existing().authorId == request.auth.uid)
                    && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt']);
      allow delete: if isSuperAdmin() || isAdmin() || (existing().authorId == request.auth.uid);
    }
    
    match /likes/{likeId} {
      function isValidLike(data) {
        return data.keys().hasAll(['postId', 'authorId', 'createdAt'])
               && data.size() == 3
               && data.postId is string && data.postId.size() <= 128
               && data.authorId == request.auth.uid
               && data.createdAt == request.time;
      }
      allow read: if true;
      allow create: if isSignedIn() && isValidId(likeId) 
                    && isValidLike(incoming())
                    && exists(/databases/$(database)/documents/posts/$(incoming().postId));
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
      allow update: if false; // likes are immutable, delete and recreate if needed
    }
  }
}
